const NT = ["马太福音","马可福音","路加福音","约翰福音","使徒行传","罗马书","哥林多前书","哥林多后书","加拉太书","以弗所书","腓立比书","歌罗西书","帖撒罗尼迦前书","帖撒罗尼迦后书","提摩太前书","提摩太后书","提多书","腓利门书","希伯来书","雅各书","彼得前书","彼得后书","约翰一书","约翰二书","约翰三书","犹大书","启示录"];

const map = ['','mudao','zhengdao','hunyin','zanmei','jianzheng','shipin','shengyue','chuxin','dongman','shenxue'];
const labels = ['','福音传播爱·慕道','福音传播爱·证道','福音传播爱·婚姻','福音传播爱·诗歌','福音传播爱·见证','福音传播爱·视频','福音传播爱·圣乐','福音传播爱·造就','福音传播爱·动漫','福音传播爱·神学'];
const catLabels = {mudao:1,zhengdao:2,hunyin:3,zanmei:4,jianzheng:5,shipin:6,shengyue:7,chuxin:8,dongman:9,shenxue:10};

// ===== 状态 =====
let curTab=0, curSlide=0, slideTimer, mobOpen=false, dark=false;
const PAGE_SIZE=20; let curPage=0, searchResults=null;

// ===== 渲染函数 =====
function rv(tab,el){
  const g=document.getElementById('videoGrid');
  if(!g) return;
  let list;
  if(searchResults!==null) list=searchResults;
  else if(tab===0) list=[...V].reverse();
  else list=V.filter(v=>catLabels[v.c]===tab);
  curPage=0;
  renderPage(list,g);
  if(el){document.querySelectorAll('#videoTabs button').forEach(b=>b.classList.remove('active'));el.classList.add('active')}
}

function renderPage(list,g){
  const start=curPage*PAGE_SIZE, end=Math.min(start+PAGE_SIZE,list.length);
  const page=list.slice(start,end);
  if(!page.length){g.innerHTML='<div style="text-align:center;padding:40px;color:var(--text-light)">暂无视频</div>';return}
  let html='';
  for(const v of page){
    const catName=labels[catLabels[v.c]]||v.cat||'福音传播爱';
    html+='<div class="card" onclick="pv('+v.id+')">'
      +'<div class="card-img" style="background:linear-gradient(135deg,#b8860b,#d4a843);display:flex;align-items:center;justify-content:center;font-size:48px;color:#fff">▶</div>'
      +'<div class="card-body"><h3>'+v.t+'</h3><p>'+v.d+'</p>'
      +'<div class="card-meta"><span>📂 '+catName+'</span><span>🆔 '+v.movid+'</span></div></div></div>';
  }
  // 分页
  const totalPages=Math.ceil(list.length/PAGE_SIZE);
  if(totalPages>1){
    let pg='<div style="grid-column:1/-1;display:flex;justify-content:center;gap:8px;margin-top:16px;flex-wrap:wrap">';
    pg+='<button onclick="goPage(-1)" style="padding:6px 14px;border:1px solid rgba(184,134,11,0.2);border-radius:6px;background:transparent;color:var(--text);cursor:pointer">\u2039</button>';
    for(let i=0;i<totalPages;i++){
      const a=i===curPage?'background:rgba(184,134,11,0.12);color:var(--primary)':'background:transparent;color:var(--text-light)';
      pg+='<button onclick="goPage('+i+')" style="padding:6px 12px;border:1px solid rgba(184,134,11,0.2);border-radius:6px;'+a+';cursor:pointer">'+(i+1)+'</button>';
    }
    pg+='<button onclick="goPage(-2)" style="padding:6px 14px;border:1px solid rgba(184,134,11,0.2);border-radius:6px;background:transparent;color:var(--text);cursor:pointer">\u203a</button>';
    pg+='</div>';
    html+=pg;
  }
  g.innerHTML=html;
}

function goPage(p){
  if(p===-1&&curPage>0) curPage--;
  else if(p===-2) {const total=Math.ceil((searchResults||[...V].reverse()).length/PAGE_SIZE);if(curPage<total-1)curPage++;}
  else curPage=p;
  const g=document.getElementById('videoGrid');
  renderPage(searchResults!==null?searchResults:(curTab===0?[...V].reverse():V.filter(v=>catLabels[v.c]===curTab)),g);
}

// ===== 搜索 =====
function ts(){document.getElementById('searchOverlay').classList.add('open');document.getElementById('searchInput').focus()}
function closeSearch(){document.getElementById('searchOverlay').classList.remove('open')}
function qs(kw){document.getElementById('searchInput').value=kw;doSearch(kw);closeSearch()}
function searchVideo(e){if(e.key!=='Enter')return;const q=document.getElementById('searchInput').value.trim();if(q)doSearch(q)}
function doSearch(q){
  const ql=q.toLowerCase();
  const r=V.filter(v=>v.t.toLowerCase().includes(ql)||v.cat.toLowerCase().includes(ql)||v.d.toLowerCase().includes(ql)||(v.l&&v.l.toLowerCase().includes(ql))||(v.s&&v.s.toLowerCase().includes(ql)));
  searchResults=r.length?r:null;
  curTab=0;
  const g=document.getElementById('videoGrid');
  if(!r.length){g.innerHTML='<div style="text-align:center;padding:40px;color:var(--text-light)">未找到"'+q+'"的相关视频</div>';return}
  renderPage(r,g);
  document.querySelectorAll('#videoTabs button').forEach((b,i)=>{b.classList.toggle('active',i===0)});
}
// ===== 播放器（B站优先，福音TV备用） =====
let curSource='bilibili';
function switchSource(src,btn,id){
  document.querySelectorAll('.src-btn').forEach(b=>{b.style.background='transparent';b.style.color=src==='bilibili'?'#00a1d6':'#b8860b';b.style.borderColor=src==='bilibili'?'#00a1d6':'#b8860b'});
  btn.style.background=btn.style.borderColor;btn.style.color='#fff';
  curSource=src;
  const v=V.find(x=>x.id===id); if(!v) return;
  const f=document.getElementById('playerFrame'); if(!f) return;
  const tip=document.getElementById('playerTip');
  if(src==='bilibili'){
    const bv=bvidMap[v.id];
    if(bv){
      f.src='https://player.bilibili.com/player.html?bvid='+bv+'&autoplay=0&high_quality=1';
      if(tip) tip.style.display='none';
    } else {
      f.src='about:blank';
      if(tip){tip.textContent='\u26a0\ufe0f \u8be5\u89c6\u9891\u6682\u65e0B\u7ad9\u64ad\u653e\u6e90';tip.style.display='block'}
    }
  } else if(src==='fuyintv'){
    f.src='about:blank';
    if(tip){tip.textContent='\u26a0\ufe0f \u798f\u97f3TV\u5b98\u7f51\uff08fuyin.tv\uff09\u5f53\u524d\u65e0\u6cd5\u8bbf\u95ee';tip.style.display='block'}
  }
}
function pv(id){
  const v=V.find(x=>x.id===id);
  if(!v) return;
  const p=document.getElementById('playerOverlay');
  const f=document.getElementById('playerFrame');
  const t=document.getElementById('playerTitle');
  const desc=document.getElementById('playerDesc');
  const sb=document.getElementById('sourceBtns');
  const tip=document.getElementById('playerTip');
  const catName=labels[catLabels[v.c]]||v.cat||'\u798f\u97f3\u4f20\u64ad\u7231';
  const hasBv=!!(typeof bvidMap!=='undefined'&&bvidMap[v.id]);
  if(t) t.textContent=v.t;
  if(desc) desc.textContent=catName+(v.s==='B\u7ad9'?'':' - \u6765\u81ea\u798f\u97f3TV');
  if(tip) tip.style.display='none';
  let html='';
  if(hasBv){
    html='<button class="src-btn" style="padding:6px 16px;border:1px solid #00a1d6;border-radius:6px;background:#00a1d6;color:#fff;font-size:13px;cursor:pointer;margin-right:6px" onclick="switchSource(\'bilibili\',this,'+id+')">\u25b6 B\u7ad9\u64ad\u653e</button>';
    html+='<button class="src-btn" style="padding:6px 16px;border:1px solid #b8860b;border-radius:6px;background:transparent;color:#b8860b;font-size:13px;cursor:pointer;margin-right:6px" onclick="switchSource(\'fuyintv\',this,'+id+')">\u25b6 \u798f\u97f3TV</button>';
    curSource='bilibili';
    const bv=bvidMap[v.id];
    if(f && bv) f.src='https://player.bilibili.com/player.html?bvid='+bv+'&autoplay=0&high_quality=1';
  } else {
    html='<button class="src-btn" style="padding:6px 16px;border:1px solid #888;border-radius:6px;background:#888;color:#fff;font-size:13px;cursor:default">\u26a0 \u6682\u65e0\u53ef\u7528\u64ad\u653e\u6e90</button>';
    curSource='fuyintv';
    if(f) f.src='about:blank';
    if(tip){tip.textContent='\u26a0\ufe0f \u8be5\u89c6\u9891\u6682\u65e0B\u7ad9\u64ad\u653e\u6e90\uff0c\u798f\u97f3TV\u5b98\u7f51\u5f53\u524d\u65e0\u6cd5\u8bbf\u95ee';tip.style.display='block'}
  }
  if(sb) sb.innerHTML=html;
  if(p) p.classList.add('open');
}
function cp(){document.getElementById('playerOverlay').classList.remove('open');const f=document.getElementById('playerFrame');if(f)f.src=''}

// ===== 暗色模式 =====
function td(){
  dark=!dark;document.documentElement.classList.toggle('dark-mode',dark);
  document.getElementById('themeBtn').textContent=dark?'☀️':'🌙';
}

// ===== 移动菜单 =====
function tm(){mobOpen=!mobOpen;document.getElementById('mobileMenu').classList.toggle('open',mobOpen)}
function cm(){mobOpen=false;document.getElementById('mobileMenu').classList.remove('open')}

// ===== 滚动 =====
function st(){window.scrollTo({top:0,behavior:'smooth'})}
function sv(){document.getElementById('videos').scrollIntoView({behavior:'smooth'})}
function ss(){document.getElementById('speakers').scrollIntoView({behavior:'smooth'})}
function sb(){document.getElementById('bible').scrollIntoView({behavior:'smooth'})}

// ===== Tab切换 =====
function sw(i,el){searchResults=null;curTab=i;rv(i,el)}
function sb2(i,el){rb(i,el)}

// ===== 轮播 =====
function gs(i){curSlide=i;updateSlider();resetTimer()}
function ps(){curSlide=(curSlide-1+3)%3;updateSlider();resetTimer()}
function ns(){curSlide=(curSlide+1)%3;updateSlider();resetTimer()}
function updateSlider(){const s=document.getElementById('heroSlider');if(s)s.style.transform='translateX(-'+curSlide*100+'%)';document.querySelectorAll('#heroDots button').forEach((b,i)=>b.classList.toggle('active',i===curSlide))}
function resetTimer(){clearInterval(slideTimer);slideTimer=setInterval(ns,5000)}

// ===== 讲员渲染 =====
function renderSpeakers(){
  const g=document.getElementById('speakerGrid');
  if(!g||!SP) return;
  g.innerHTML=SP.map(s=>'<div class="speaker-card"><div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#b8860b,#d4a843);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:28px;color:#fff">✝</div><h4>'+s+'</h4><p>牧者讲员</p></div>').join('');
}

// ===== 圣经 =====
function rb(idx,el){
  const g=document.getElementById('bibleGrid');
  if(!g) return;
  const list=idx===0?OT:NT;
  g.innerHTML=list.map(b=>'<button onclick="window.open(\'https://www.wordproject.org/bibles/audio/04_chinese/06_'+b+'.htm\',\'_blank\')">'+b+'</button>').join('');
  if(el){document.querySelectorAll('#bibleTabs button').forEach(b=>b.classList.remove('active'));el.classList.add('active')}
}

// ===== 进度条 & 导航高亮 =====
function updateProgress(){
  const p=document.getElementById('progress-bar');
  if(!p)return;
  const s=window.scrollY/(document.body.scrollHeight-window.innerHeight);
  p.style.width=Math.min(s*100,100)+'%';
}
function highlightNav(){
  const sections=['home','videos','speakers','bible','about'];
  let cur='home';
  for(const id of sections){
    const el=document.getElementById(id);
    if(el&&window.scrollY>=el.offsetTop-200) cur=id;
  }
  document.querySelectorAll('.nav-links a,.mobile-menu a').forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+cur));
}

// ===== 启动 =====
document.addEventListener('DOMContentLoaded',()=>{
  rv(0);
  renderSpeakers();
  rb(0);
  gs(0);
  updateSlider();
  slideTimer=setInterval(ns,5000);
  window.addEventListener('scroll',()=>{updateProgress();highlightNav()});
  document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeSearch();cp()}});
});
</script>

</body>
</html>