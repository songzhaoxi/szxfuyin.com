<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>福音传播爱 - szxfuyin.com | 基督教福音视频平台</title>
<meta name="description" content="福音传播爱 - 基督教福音视频网站，福音传播爱系列，分享慕道、证道、婚姻家庭、赞美诗歌等属灵资源。szxfuyin.com丨www.szxfuyin.com">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--primary:#b8860b;--primary-light:#d4a843;--bg:#f8f5f0;--bg-card:#fff;--bg-dark:#1a1a2e;--text:#2c3e50;--text-light:#7f8c8d;--text-dark:#e0e0e0;--shadow:0 4px 20px rgba(0,0,0,0.08);--shadow-hover:0 8px 30px rgba(0,0,0,0.15);--radius:12px;--radius-sm:8px;--gold:linear-gradient(135deg,#b8860b,#d4a843,#b8860b);--header-h:68px;--transition:all 0.3s ease}
.dark-mode{--bg:#0f0f23;--bg-card:#1a1a35;--bg-card-dark:#12122a;--text:#e0e0e0;--text-light:#a0a0b0}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;background:var(--bg);color:var(--text);line-height:1.6;transition:var(--transition)}
#progress-bar{position:fixed;top:0;left:0;height:3px;background:var(--gold);width:0%;z-index:10001;transition:width 0.1s}
header{position:fixed;top:0;left:0;right:0;height:var(--header-h);z-index:9999;backdrop-filter:blur(20px);background:rgba(248,245,240,0.88);border-bottom:1px solid rgba(184,134,11,0.1);transition:var(--transition)}
.dark-mode header{background:rgba(15,15,35,0.88)}header .container{max-width:1200px;margin:0 auto;padding:0 20px;height:100%;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:10px}.logo-icon{width:40px;height:40px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;font-weight:bold}
.logo-text h1{font-size:20px;font-weight:700;background:var(--gold);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.logo-text small{font-size:11px;color:var(--text-light)}
.nav-links{display:flex;align-items:center;gap:8px}.nav-links a{padding:8px 16px;border-radius:var(--radius-sm);font-size:14px;color:var(--text);transition:var(--transition)}.nav-links a:hover,.nav-links a.active{background:rgba(184,134,11,0.12);color:var(--primary)}
.nav-btn{width:38px;height:38px;border:none;border-radius:50%;background:rgba(184,134,11,0.08);color:var(--text);font-size:16px;cursor:pointer;transition:var(--transition);display:inline-flex;align-items:center;justify-content:center}.nav-btn:hover{background:rgba(184,134,11,0.2);color:var(--primary)}
.mobile-toggle{display:none;width:38px;height:38px;border:none;background:none;color:var(--text);font-size:24px;cursor:pointer}
.mobile-menu{display:none;position:fixed;top:var(--header-h);left:0;right:0;background:var(--bg);padding:16px 20px;z-index:9998;box-shadow:var(--shadow);transform:translateY(-100%);opacity:0;transition:var(--transition)}.mobile-menu.open{transform:translateY(0);opacity:1}
.mobile-menu a{display:block;padding:12px 16px;font-size:15px;color:var(--text);border-radius:var(--radius-sm)}.mobile-menu a:hover{background:rgba(184,134,11,0.12);color:var(--primary)}
.search-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:10000;align-items:flex-start;justify-content:center;padding-top:120px}.search-overlay.open{display:flex}
.search-box{width:90%;max-width:600px;background:var(--bg-card);border-radius:20px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}.search-box input{width:100%;padding:14px 18px;font-size:16px;border:2px solid rgba(184,134,11,0.2);border-radius:8px;background:var(--bg);color:var(--text);outline:none}.search-box input:focus{border-color:var(--primary)}
.hero{position:relative;height:520px;overflow:hidden}.hero-slider{display:flex;width:100%;height:100%;transition:transform 0.7s ease}.hero-slide{min-width:100%;height:100%;position:relative;display:flex;align-items:center;justify-content:center;padding:0 20px}.hero-slide::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,0,0,0.7),rgba(0,0,0,0.3));z-index:1}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center}.hero-content{position:relative;z-index:2;max-width:700px;text-align:center;color:#fff}.hero-content h2{font-size:clamp(28px,5vw,48px);font-weight:700;margin-bottom:16px;text-shadow:0 2px 20px rgba(0,0,0,0.3)}.hero-content h2 .hl{background:var(--gold);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.badge{display:inline-block;padding:4px 16px;border-radius:20px;background:rgba(255,255,255,0.15);color:#fff;font-size:13px;font-weight:600;letter-spacing:1px;margin-bottom:12px;backdrop-filter:blur(4px)}.btn-group{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}.search-close{position:absolute;top:80px;right:30px;width:44px;height:44px;border:none;border-radius:50%;background:rgba(255,255,255,0.2);color:#fff;font-size:22px;cursor:pointer;z-index:10001;display:flex;align-items:center;justify-content:center}.search-close:hover{background:rgba(255,255,255,0.35)}.search-tips{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}.search-tips span{padding:6px 14px;border-radius:16px;background:rgba(184,134,11,0.08);color:var(--primary);font-size:13px;cursor:pointer;transition:all 0.2s}.search-tips span:hover{background:rgba(184,134,11,0.2)}.hero-content p{font-size:16px;opacity:0.9;margin-bottom:24px}
.btn-primary{padding:12px 32px;border:none;border-radius:var(--radius-sm);background:var(--gold);color:#fff;font-size:15px;font-weight:600;cursor:pointer;transition:var(--transition)}.btn-primary:hover{transform:translateY(-2px)}
.btn-outline{padding:12px 32px;border:2px solid rgba(255,255,255,0.4);border-radius:var(--radius-sm);background:transparent;color:#fff;font-size:15px;font-weight:600;cursor:pointer}.btn-outline:hover{border-color:#fff}
.hero-dots{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);display:flex;gap:10px;z-index:3}.hero-dots button{width:10px;height:10px;border-radius:50%;border:2px solid rgba(255,255,255,0.5);background:transparent;cursor:pointer;padding:0}.hero-dots button.active{background:#fff;width:30px;border-radius:5px}
.hero-arrows{position:absolute;top:50%;left:0;right:0;transform:translateY(-50%);display:flex;justify-content:space-between;padding:0 20px;z-index:3;pointer-events:none}.hero-arrows button{width:48px;height:48px;border:none;border-radius:50%;background:rgba(255,255,255,0.15);color:#fff;font-size:20px;cursor:pointer;pointer-events:auto}.hero-arrows button:hover{background:rgba(255,255,255,0.3)}
.section{padding:70px 20px;max-width:1200px;margin:0 auto}.section-header{text-align:center;margin-bottom:44px}.section-header .tag{display:inline-block;padding:4px 16px;border-radius:20px;background:rgba(184,134,11,0.1);color:var(--primary);font-size:13px;font-weight:600;letter-spacing:2px;margin-bottom:8px}.section-header h2{font-size:clamp(24px,3vw,32px);font-weight:700;margin-bottom:8px}.section-header h2 .hl{background:var(--gold);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.section-header p{color:var(--text-light);font-size:15px;max-width:500px;margin:0 auto}
.tabs{display:flex;justify-content:center;gap:6px;margin-bottom:32px;flex-wrap:wrap}.tabs button{padding:8px 20px;border:1px solid rgba(184,134,11,0.2);border-radius:20px;background:transparent;color:var(--text-light);font-size:14px;cursor:pointer;transition:var(--transition)}.tabs button:hover,.tabs button.active{border-color:var(--primary);color:var(--primary);background:rgba(184,134,11,0.08)}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px}
.card{background:var(--bg-card);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);transition:var(--transition);cursor:pointer}.card:hover{box-shadow:var(--shadow-hover);transform:translateY(-4px)}
.card-img{width:100%;height:180px;object-fit:cover;display:block}.card-body{padding:16px}.card-body h3{font-size:16px;font-weight:600;margin-bottom:6px}.card-body p{font-size:13px;color:var(--text-light)}.card-meta{display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:10px;border-top:1px solid rgba(0,0,0,0.06);font-size:12px;color:var(--text-light)}
.speaker-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:16px}
.speaker-card{background:var(--bg-card);border-radius:var(--radius);padding:20px;text-align:center;box-shadow:var(--shadow);transition:var(--transition);cursor:pointer}.speaker-card:hover{box-shadow:var(--shadow-hover);transform:translateY(-4px)}.speaker-card img{width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:10px;border:3px solid rgba(184,134,11,0.2)}.speaker-card h4{font-size:14px;font-weight:600}.speaker-card p{font-size:12px;color:var(--text-light)}
.bible-section{background:var(--bg-card);border-radius:var(--radius);padding:30px;box-shadow:var(--shadow)}.bible-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:8px;max-height:400px;overflow-y:auto;padding:10px}.bible-grid button{padding:6px 10px;border:1px solid rgba(184,134,11,0.15);border-radius:6px;background:transparent;color:var(--text);font-size:13px;cursor:pointer;transition:var(--transition)}.bible-grid button:hover{background:rgba(184,134,11,0.1);color:var(--primary)}
.player-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.85);z-index:10002;align-items:center;justify-content:center}.player-overlay.open{display:flex}.player-box{width:90%;max-width:800px;background:var(--bg-card);border-radius:var(--radius);overflow:hidden}.player-box video{width:100%;display:block;max-height:500px;background:#000}.player-info{padding:20px}.player-info h3{font-size:18px;margin-bottom:4px}.player-info p{font-size:14px;color:var(--text-light)}.player-close{position:absolute;top:20px;right:20px;width:40px;height:40px;border:none;border-radius:50%;background:rgba(255,255,255,0.15);color:#fff;font-size:24px;cursor:pointer}
footer{background:var(--bg-card);padding:50px 20px 30px;border-top:1px solid rgba(184,134,11,0.1)}.dark-mode footer{background:var(--bg-card-dark)}footer .container{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:30px}footer h4{font-size:16px;font-weight:600;margin-bottom:12px}footer p,footer a{font-size:14px;color:var(--text-light);line-height:2}footer .copyright{text-align:center;padding-top:30px;margin-top:30px;border-top:1px solid rgba(0,0,0,0.06);font-size:13px;color:var(--text-light);grid-column:1/-1}
@media(max-width:768px){.nav-links{display:none}.mobile-toggle{display:block}.mobile-menu{display:block}.hero{height:400px}.hero-content h2{font-size:28px}.section{padding:40px 16px}.grid{grid-template-columns:1fr 1fr}.speaker-grid{grid-template-columns:repeat(auto-fill,minmax(120px,1fr))}}
@media(max-width:480px){.grid{grid-template-columns:1fr}.hero{height:360px}}
@keyframes annPulse{0%,100%{opacity:1}50%{opacity:0.6}}.announcement-bar{background:linear-gradient(135deg,#1a1a2e,#2c2c54);color:#fff;padding:8px 0;font-size:13px;position:relative;z-index:999;border-bottom:1px solid rgba(184,134,11,0.2);text-align:center}.announcement-bar .container{max-width:1200px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap}.announcement-icon{font-size:16px;animation:annPulse 2s infinite}.announcement-text strong{color:#d4a843}.announcement-verse{color:#b8860b;font-style:italic;font-size:12px;margin-left:4px}.announcement-close{background:none;border:none;color:rgba(255,255,255,0.6);font-size:16px;cursor:pointer;padding:2px 6px;border-radius:50%}.announcement-close:hover{color:#fff;background:rgba(255,255,255,0.1)}
.about-section{background:var(--bg-card);border-radius:var(--radius);padding:40px;margin:40px auto;max-width:900px;box-shadow:var(--shadow)}.about-section h3{font-size:22px;font-weight:700;margin-bottom:16px;text-align:center}.about-section h3 span{background:var(--gold);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.about-section p{font-size:15px;color:var(--text-light);line-height:1.8;margin-bottom:12px}.about-section .verse{text-align:center;font-style:italic;color:var(--primary);margin:20px 0;padding:16px;border-left:4px solid var(--primary);background:rgba(184,134,11,0.05);border-radius:var(--radius-sm)}
</style>
</head>
