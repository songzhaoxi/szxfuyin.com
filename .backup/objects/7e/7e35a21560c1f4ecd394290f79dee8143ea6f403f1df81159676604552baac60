const NT = ["马太福音","马可福音","路加福音","约翰福音","使徒行传","罗马书","哥林多前书","哥林多后书","加拉太书","以弗所书","腓立比书","歌罗西书","帖撒罗尼迦前书","帖撒罗尼迦后书","提摩太前书","提摩太后书","提多书","腓利门书","希伯来书","雅各书","彼得前书","彼得后书","约翰一书","约翰二书","约翰三书","犹大书","启示录"];

let curSlide=0, slideTimer, curTab=0;

// ===== 渲染函数 =====
function rv(tab,el){
  const g = document.getElementById('videoGrid');
  let list;
  const map = ['','慕道','证道','家庭','赞美'];
  if(tab===0) list=[...V].reverse();
  else list=V.filter(v=>v.c===map[tab]);
  if(!g) return;
  if(list.length===0){
    g.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-light)">暂无视频，敬请期待</div>';
    return;
  }
  g.innerHTML=list.map(v=>`
    <div class="card" onclick="pv(${v.id})">
      <div class="card-img" style="background:linear-gradient(135deg,#b8860b,#d4a843);display:flex;align-items:center;justify-content:center;font-size:40px;color:#fff">▶</div>
      <div class="card-body">
        <h3>${v.t}</h3>
        <p>${v.d}</p>
        <div class="card-meta">
          <span>👤 ${v.s}</span>
          <span>⏱ ${v.l}</span>
          <span>👁 ${v.v}</span>
        </div>
      </div>
    </div>`).join('');
  if(el){
    document.querySelectorAll('#videoTabs button').forEach(b=>b.classList.remove('active'));
    el.classList.add('active');
  }
}

function rs(){
  const g = document.getElementById('speakerGrid');
  if(!g) return;
  g.innerHTML=SP.map(n=>`
    <div class="speaker-card" onclick="qs('${n}')">
      <div style="width:80px;height:80px;border-radius:50%;margin:0 auto 10px;background:linear-gradient(135deg,#b8860b,#d4a843);display:flex;align-items:center;justify-content:center;font-size:32px;color:#fff;border:3px solid rgba(184,134,11,0.2)">✝</div>
      <h4>${n}</h4>
      <p>讲员</p>
    </div>`).join('');
}

function rb(idx,el){
  const g = document.getElementById('bibleGrid');
  if(!g) return;
  const data = idx===0?OT:NT;
  g.innerHTML=data.map(b=>`<button onclick="qs('${b}')">${b}</button>`).join('');
  if(el){
    document.querySelectorAll('#bibleTabs button').forEach(b=>b.classList.remove('active'));
    el.classList.add('active');
  }
}

// ===== 轮播 =====
function gs(i){curSlide=i;updateSlider();resetTimer()}
function ps(){curSlide=(curSlide-1+3)%3;updateSlider();resetTimer()}
function ns(){curSlide=(curSlide+1)%3;updateSlider();resetTimer()}
function updateSlider(){
  const s=document.getElementById('heroSlider');
  if(s)s.style.transform='translateX(-'+curSlide*100+'%)';
  document.querySelectorAll('#heroDots button').forEach((b,i)=>b.classList.toggle('active',i===curSlide));
}
function resetTimer(){clearInterval(slideTimer);slideTimer=setInterval(ns,5000)}
function startSlider(){slideTimer=setInterval(ns,5000)}

// ===== 搜索 =====
function ts(){document.getElementById('searchOverlay').classList.add('open');document.getElementById('searchInput').focus()}
function closeSearch(){document.getElementById('searchOverlay').classList.remove('open')}
function qs(kw){document.getElementById('searchInput').value=kw;searchVideo({key:'Enter'});closeSearch()}
function searchVideo(e){
  if(e.key!=='Enter'&&e.key!==undefined) return;
  const q=document.getElementById('searchInput').value.trim();
  if(!q) return;
  const r=V.filter(v=>v.t.includes(q)||v.s.includes(q)||v.d.includes(q));
  const g=document.getElementById('videoGrid');
  if(r.length===0) g.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-light)">未找到 " '+q+' " 相关内容</div>';
  else g.innerHTML=r.map(v=>`
    <div class="card" onclick="pv(${v.id})">
      <div class="card-img" style="background:linear-gradient(135deg,#b8860b,#d4a843);display:flex;align-items:center;justify-content:center;font-size:40px;color:#fff">▶</div>
      <div class="card-body"><h3>${v.t}</h3><p>${v.d}</p><div class="card-meta"><span>👤 ${v.s}</span><span>⏱ ${v.l}</span></div></div>
    </div>`).join('');
  document.querySelectorAll('#videoTabs button').forEach(b=>b.classList.remove('active'));
  closeSearch();
  document.getElementById('videos').scrollIntoView({behavior:'smooth'});
}

// ===== 播放器 =====
function pv(id){
  const v=V.find(x=>x.id===id);
  if(!v) return;
  const p=document.getElementById('playerOverlay');
  const video=document.getElementById('playerVideo');
  const title=document.getElementById('playerTitle');
  const desc=document.getElementById('playerDesc');
  if(video) video.src=''; // placeholder
  if(title) title.textContent=v.t+' - '+v.s;
  if(desc) desc.textContent=v.d+' | 时长: '+v.l+' | 观看: '+v.v;
  if(p) p.classList.add('open');
}
function cp(){document.getElementById('playerOverlay').classList.remove('open');const v=document.getElementById('playerVideo');if(v)v.pause()}

// ===== 暗色模式 =====
let dark=false;
function td(){
  dark=!dark;
  document.body.classList.toggle('dark-mode',dark);
  document.getElementById('themeBtn').textContent=dark?'☀️':'🌙';
}

// ===== 移动端菜单 =====
let mobOpen=false;
function tm(){mobOpen=!mobOpen;document.getElementById('mobileMenu').classList.toggle('open',mobOpen)}
function cm(){mobOpen=false;document.getElementById('mobileMenu').classList.remove('open')}

// ===== 滚动 =====
function st(){window.scrollTo({top:0,behavior:'smooth'})}
function sv(){document.getElementById('videos').scrollIntoView({behavior:'smooth'})}
function ss(){document.getElementById('speakers').scrollIntoView({behavior:'smooth'})}
function sb(){document.getElementById('bible').scrollIntoView({behavior:'smooth'})}

// ===== Tab切换 =====
function sw(i,el){curTab=i;rv(i,el)}
function sb2(i,el){rb(i,el)}

// ===== 进度条 =====
function updateProgress(){
  const h=document.documentElement;
  const p=(h.scrollTop||document.body.scrollTop)/(h.scrollHeight-h.clientHeight)*100;
  document.getElementById('progress-bar').style.width=p+'%';
}

// ===== 导航高亮 =====
function highlightNav(){
  const sections=['home','videos','speakers','bible','about'];
  const links=document.querySelectorAll('.nav-links a');
  let cur='home';
  sections.forEach(id=>{
    const el=document.getElementById(id);
    if(el&&window.scrollY>=el.offsetTop-200) cur=id;
  });
  links.forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+cur));
}

// ===== 初始化 =====
window.addEventListener('load',()=>{
  rv(0);
  rs();
  rb(0);
  startSlider();
  window.addEventListener('scroll',()=>{updateProgress();highlightNav()});
  document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeSearch();cp()}});
});
</script>

